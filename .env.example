# Supabase - get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# YouTube Data API v3 - get from Google Cloud Console
YOUTUBE_API_KEY=your-youtube-api-key-here

# Dodo Payments - get from your Dodo Payments dashboard
DODO_PAYMENTS_API_KEY=your-dodo-api-key-here
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret-here

# Dodo Payments product/price ID for Pro plan
DODO_PRO_PRODUCT_ID=your-dodo-product-id-here

# App URL (used for webhook and redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

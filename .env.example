# Supabase — get from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# YouTube Data API v3 — get from Google Cloud Console
YOUTUBE_API_KEY=your-youtube-api-key-here

# Supertab Payments — get from https://business.supertab.co
# No monthly fee; holds funds until KYC; works with MoMo virtual card
#
# Step 1: Business Portal > API Keys > Create API Key
SUPERTAB_CLIENT_ID=your-api-key-client-id-here
SUPERTAB_API_KEY=your-api-key-client-secret-here
#
# Step 2: Business Portal > Sites > Create Site (URL = your Vercel domain)
#         Copy the live_client.xxxx ID shown for that site
SUPERTAB_SITE_CLIENT_ID=your-site-client-id-here
#
# Step 3: Business Portal > Webhooks > Add Endpoint > copy signing secret
SUPERTAB_WEBHOOK_SECRET=your-webhook-secret-here

# App URL — set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — get from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# YouTube Data API v3 — get from Google Cloud Console
YOUTUBE_API_KEY=your-youtube-api-key-here

# Supertab Payments — get from https://business.supertab.co > API Keys
# No monthly fee; holds funds until KYC; works with MoMo virtual card
SUPERTAB_API_KEY=your-supertab-client-secret-here
SUPERTAB_CLIENT_ID=your-supertab-client-id-here
SUPERTAB_WEBHOOK_SECRET=your-supertab-webhook-secret-here

# App URL — set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
